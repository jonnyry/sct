{
  "name": "sct-video",
  "version": "1.0.0",
  "description": "Remotion walkthrough video for the sct SNOMED CT toolchain",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render SctWalkthrough out/sct-walkthrough.mp4",
    "still": "remotion still SctWalkthrough --frame=0 out/still.png"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.443",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "remotion": "^4.0.443"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "remotion": {
    "entryPoint": "src/index.ts"
  }
}
